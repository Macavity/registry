{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://unpkg.com/@grove/manifest-schema@0.1.0/schemas/widget.schema.json",
  "title": "Grove Widget Manifest (v1 stub)",
  "description": "widget.json — placeholder for v1; the full widget schema is deferred to v1.x and will break this shape.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 50,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "object",
      "properties": {
        "default": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "de": {
          "type": "string"
        },
        "es": {
          "type": "string"
        },
        "zh-Hans": {
          "type": "string"
        },
        "zh-Hant": {
          "type": "string"
        }
      },
      "required": [
        "default"
      ],
      "additionalProperties": false
    },
    "description": {
      "type": "object",
      "properties": {
        "default": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "de": {
          "type": "string"
        },
        "es": {
          "type": "string"
        },
        "zh-Hans": {
          "type": "string"
        },
        "zh-Hant": {
          "type": "string"
        }
      },
      "required": [
        "default"
      ],
      "additionalProperties": false
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "authorUrl": {
      "type": "string"
    },
    "minGroveVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[\\w.+-]+( WITH [\\w.+-]+)?$"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "readme": {
      "type": "object",
      "properties": {
        "default": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "de": {
          "type": "string"
        },
        "es": {
          "type": "string"
        },
        "zh-Hans": {
          "type": "string"
        },
        "zh-Hant": {
          "type": "string"
        }
      },
      "required": [
        "default"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "id",
    "name",
    "description",
    "version",
    "author",
    "minGroveVersion",
    "license"
  ],
  "additionalProperties": true
}
